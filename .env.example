# Kopiera till .env (produktion) eller .env.dev (lokal dev) och fyll i värden
# Checka ALDRIG in .env eller .env.dev i git

DATABASE_PATH=data/links.db

# Lettermint SMTP
SMTP_HOST=smtp.lettermint.net
SMTP_PORT=587
SMTP_USER=din-lettermint-användare
SMTP_PASS=ditt-lettermint-lösenord
MAIL_FROM=link@svky.se

# Generera med: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Produktion: https://svky.se  |  Dev: http://localhost:8000
BASE_URL=https://svky.se
